// ==========================================
// 1. 系统与自启动 (Startup & Environment)
// ==========================================
prefer-no-csd

spawn-at-startup "sh" "-c" "sleep 1 && swww img /etc/nixos/modules/home/swww/Muzomi.png --transition-type wipe"

spawn-at-startup "sh" "-c" "systemctl --user import-environment WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE GTK_IM_MODULE QT_IM_MODULE SDL_IM_MODULE GLFW_IM_MODULE INPUT_METHOD XMODIFIERS NIXOS_OZONE_WL; dbus-update-activation-environment --systemd WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE GTK_IM_MODULE QT_IM_MODULE SDL_IM_MODULE GLFW_IM_MODULE INPUT_METHOD XMODIFIERS NIXOS_OZONE_WL"
spawn-at-startup "fcitx5" "-d"
spawn-at-startup "xwayland-satellite"
spawn-at-startup "xembedsniproxy"
spawn-at-startup "noctalia-shell"

environment {
    LANG "zh_CN.UTF-8"
    LC_ALL "zh_CN.UTF-8"
    GTK_IM_MODULE "fcitx"
    QT_IM_MODULE "fcitx"
    SDL_IM_MODULE "fcitx"
    GLFW_IM_MODULE "fcitx"
    INPUT_METHOD "fcitx"
    XMODIFIERS "@im=fcitx"
    NIXOS_OZONE_WL "1"
}

// ==========================================
// 2. 输入设备 (Input Devices)
// ==========================================
input {
    keyboard {
        xkb { options "caps:super,shift:both_capslock"; }
        numlock
    }

    mod-key "Super"

    touchpad {
        tap
        natural-scroll
    }
}

// ==========================================
// 3. 窗口布局与外观 (Layout & Visuals)
// ==========================================
layout {
    gaps 8
    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }
    default-column-width { proportion 0.5; }

    focus-ring {
        width 3
        active-color "#8FBCBB"
        inactive-color "#4C566A"
    }

    shadow {
        softness 30
        spread 5
        offset x=0 y=5
        color "#00000070"
    }
}

screenshot-path "~/Pictures/Screenshots/Screenshot_%Y-%m-%d_%H-%M-%S.png"

// ==========================================
// 4. 动画效果 (Animations)
// ==========================================
animations {
    workspace-switch {
        spring damping-ratio=1.0 stiffness=1000 epsilon=0.0001
    }
    window-open {
        duration-ms 150
        curve "ease-out-expo"
    }
    window-close {
        duration-ms 150
        curve "ease-out-quad"
    }
    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }
    window-resize {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }
}

// ==========================================
// 5. 窗口规则 (Window Rules)
// ==========================================
window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
}

window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

window-rule {
    match app-id="steam"
    default-column-width { proportion 0.7; }
}

// ==========================================
// 6. 快捷键绑定 (Keybinds)
// ==========================================
binds {
    // --- 核心应用启动 ---
    Mod+Shift+Slash { show-hotkey-overlay; }
    Mod+Return { spawn "kitty"; }
    Mod+R { spawn "fcitx5-remote" "-t"; }

    // Noctalia 官方推荐 IPC 方式
    Mod+Space { spawn "noctalia-shell" "ipc" "call" "launcher" "toggle"; }
    Mod+S { spawn "noctalia-shell" "ipc" "call" "controlCenter" "toggle"; }
    Mod+Comma { spawn "noctalia-shell" "ipc" "call" "settings" "toggle"; }

    Mod+B { spawn "firefox"; }

    // --- 硬件控制 (切到 Noctalia IPC，统一 OSD/状态) ---
    XF86AudioRaiseVolume allow-when-locked=true { spawn "noctalia-shell" "ipc" "call" "volume" "increase"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "noctalia-shell" "ipc" "call" "volume" "decrease"; }
    XF86AudioMute        allow-when-locked=true { spawn "noctalia-shell" "ipc" "call" "volume" "muteOutput"; }

    XF86MonBrightnessUp   allow-when-locked=true { spawn "noctalia-shell" "ipc" "call" "brightness" "increase"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "noctalia-shell" "ipc" "call" "brightness" "decrease"; }

    // --- 窗口操作 ---
    Mod+Q { close-window; }
    Mod+V { toggle-window-floating; }
    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; }

    // --- 焦点移动 ---
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+H     { focus-column-left; }
    Mod+L     { focus-column-right; }
    Mod+J     { focus-window-down; }
    Mod+K     { focus-window-up; }

    // --- 移动窗口位置 ---
    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Right { move-column-right; }
    Mod+Ctrl+H     { move-column-left; }
    Mod+Ctrl+L     { move-column-right; }
    Mod+Ctrl+J     { move-window-down; }
    Mod+Ctrl+K     { move-window-up; }

    // --- 工作区切换 ---
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }

    // --- 移动窗口到指定工作区 ---
    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }

    // --- 退出与锁屏 ---
    Mod+Shift+E { quit; }
    Mod+Shift+L { spawn "hyprlock"; }

    Print { screenshot; }
}
